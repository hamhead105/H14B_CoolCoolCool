// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  orderId                  String   @id
  status                   String
  inputData                Json
  totalCost                Float
  taxAmount                Float
  payableAmount            Float
  anticipatedMonetaryTotal Float
  loyaltyPointsEarned      Int      @default(0)
  loyaltyPointsRedeemed    Int      @default(0)
  createdAt                DateTime @default(now())
}

model Product {
  productId                String   @id
  sellerId                 String
  name                     String
  description              String
  cost                     Float
  brand                    String
  family                   String
  onSpecial                Boolean
  discount                 Float
  productTier              Int
  nextProduct              String
  releaseDate              DateTime @default(now())
}

model buyer {
  buyerId              String  @id
  encryptedPassword       String
  firstName               String
  lastName                String
  address                 String
  phoneNumber             String
  email                   String
  loyaltyPoints           Int
}

model seller {
  sellerId              String  @id
  encryptedPassword       String
  company                 String
  sellerName              String
  address                 String
  phoneNumber             String
  email                   String
  loyaltyPoints           Int
}