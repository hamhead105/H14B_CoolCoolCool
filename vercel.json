{
  "version": 2,
  "builds": [
    {
      "src": "backend/src/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build"
    }
  ],
  "rewrites": [
    {
      "source": "/sellers/(.*)",
      "destination": "backend/src/server.js"
    },
    {
      "source": "/products/(.*)",
      "destination": "backend/src/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "frontend/$1"
    }
  ]
}