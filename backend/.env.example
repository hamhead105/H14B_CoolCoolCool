# Backend environment variables
# Copy to .env and update values as needed

# Database connection (for Vercel: use Supabase PostgreSQL URL)
DATABASE_URL="postgresql://user:password@localhost:5432/coolcoolcool"

# JWT secret for authentication (use same value in production)
JWT_SECRET="your-super-secret-jwt-key-min-32-chars-recommended"

# Email service (optional, if you want to send UBL emails)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# Node environment
NODE_ENV="development"

# Server port (default 3000)
PORT=3000
